# AgentProbe — Environment Variables
# Copy to .env:  cp .env.example .env

# Your Anthropic key (for the LLM-judge evaluator)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: OpenAI key (if customers test OpenAI agents)
OPENAI_API_KEY=sk-your-key-here

# PayFast (primary payment — South Africa)
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true

# Stripe (fallback — for when you set up Stripe Atlas)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_xxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxx

# App
DOMAIN=http://localhost:3000
API_DOMAIN=http://localhost:8000
ADMIN_SECRET=admin-change-me-in-production
